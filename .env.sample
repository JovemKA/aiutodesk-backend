# App
NODE_ENV=development
PORT=3000

# Auth
JWT_SECRET=change-me-for-dev
JWT_EXPIRES_IN=1d

# AI - Gemini (Google AI Studio)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.2
GEMINI_TOP_P=0.9
GEMINI_TOP_K=40
GEMINI_MAX_OUTPUT_TOKENS=1024
GEMINI_REQUEST_TIMEOUT_MS=20000
CHAT_MAX_MESSAGE_CHARS=4000

# Database (Supabase)
# Use the URI from Supabase Dashboard > Connect
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# SSL and connection tuning (recommended for Supabase)
DB_SSL_ENABLED=true
DB_SSL_REJECT_UNAUTHORIZED=false
DB_MAX_CONNECTIONS=10
DB_CONNECTION_TIMEOUT_MS=10000
DB_IDLE_TIMEOUT_MS=30000
DB_RETRY_ATTEMPTS=10
DB_RETRY_DELAY_MS=3000

# TypeORM runtime
# Set DB_SYNC=true only for local development
DB_SYNC=false
DB_LOGGING=false
