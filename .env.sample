# App
NODE_ENV=development
PORT=3000

# Auth
JWT_SECRET=change-me-for-dev
JWT_EXPIRES_IN=1d

# reCAPTCHA (Google) — protege /auth/login e /auth/signup
# Vazio em dev = verificação desativada (todas as requisições passam)
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SCORE_THRESHOLD=0.6

# AI - Gemini (Google AI Studio)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.2
GEMINI_TOP_P=0.9
GEMINI_TOP_K=40
GEMINI_MAX_OUTPUT_TOKENS=1024
GEMINI_REQUEST_TIMEOUT_MS=20000
CHAT_MAX_MESSAGE_CHARS=4000

# Triagem automática por IA ao criar chamado (prioridade + categoria + departamento).
# Roda em background, best-effort. =false desliga (criação não dispara triagem).
TRIAGE_ON_CREATE_ENABLED=true

# RAG (busca vetorial na KB)
# RAG_ENABLED=false desliga o pipeline RAG (chat volta ao modo fase 1)
RAG_ENABLED=true
# gemini-embedding-2: multilingue, multimodal-capable, mais recente (Google API).
# Alternativa text-only mais leve: gemini-embedding-001.
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
RAG_EMBEDDING_DIMENSIONS=768
RAG_TOP_K=4
RAG_MIN_SIMILARITY=0.6
RAG_FILTER_BY_DEPARTMENT=false

# Database (Supabase)
# Use the URI from Supabase Dashboard > Connect
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# SSL and connection tuning (recommended for Supabase)
DB_SSL_ENABLED=true
DB_SSL_REJECT_UNAUTHORIZED=false
DB_MAX_CONNECTIONS=10
DB_CONNECTION_TIMEOUT_MS=10000
DB_IDLE_TIMEOUT_MS=30000
DB_RETRY_ATTEMPTS=10
DB_RETRY_DELAY_MS=3000

# TypeORM runtime
# IMPORTANT: keep DB_SYNC=false. A tabela kb_article_chunks usa coluna vector(768)
# que o TypeORM nao consegue reconciliar (entity declara text + transformer).
DB_SYNC=false
DB_LOGGING=false
